@page "/admin/users"
@using Microsoft.AspNetCore.Authorization
@using MedAssist.Web.Services
@attribute [Authorize(Roles = "Admin")]
@layout AdminLayout
@inject AdminUserService AdminUsers
@rendermode InteractiveServer

<PageTitle>MedAssist — Users</PageTitle>

<h1>Users</h1>

<div class="mb-3">
    <a href="/admin/users/create" class="btn btn-primary">Add User</a>
</div>

@if (_loading)
{
    <div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div>
}
else if (_users.Count == 0)
{
    <p class="text-muted">No users found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Username</th>
                <th>Role</th>
                <th>Created</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in _users)
            {
                <tr>
                    <td>@user.Username</td>
                    <td><span class="status-pill @(user.Role == "Admin" ? "is-working" : "")">@user.Role</span></td>
                    <td class="num">@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                    <td>
                        @if (_confirmDeleteId == user.Id)
                        {
                            <span class="me-2">Are you sure?</span>
                            <button class="btn btn-sm btn-danger me-1" @onclick="() => ConfirmDeleteAsync(user.Id)">Yes, delete</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="CancelDelete">Cancel</button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RequestDelete(user.Id)">Delete</button>
                        }
                        @if (_deleteMessages.TryGetValue(user.Id, out var msg))
                        {
                            <span class="ms-2 small text-danger">@msg</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

@code {
    private List<UserInfo> _users = [];
    private bool _loading = true;
    private string? _error;
    private Guid? _confirmDeleteId;
    private readonly Dictionary<Guid, string> _deleteMessages = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _users = (await AdminUsers.GetUsersAsync()).ToList();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load users: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void RequestDelete(Guid id)
    {
        _confirmDeleteId = id;
        _deleteMessages.Remove(id);
    }

    private void CancelDelete() => _confirmDeleteId = null;

    private async Task ConfirmDeleteAsync(Guid id)
    {
        _confirmDeleteId = null;
        var (success, message) = await AdminUsers.DeleteUserAsync(id);
        if (success)
        {
            _users.RemoveAll(u => u.Id == id);
        }
        else
        {
            _deleteMessages[id] = message;
        }
    }
}

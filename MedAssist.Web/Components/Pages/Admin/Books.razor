@page "/admin/books"
@using Microsoft.AspNetCore.Authorization
@using MedAssist.Shared.Models
@using MedAssist.Web.Services
@attribute [Authorize(Roles = "Admin")]
@layout AdminLayout
@inject AdminBookService AdminBooks
@rendermode InteractiveServer

<PageTitle>MedAssist — Books</PageTitle>

<h1>Books</h1>

<div class="mb-3">
    <a href="/admin/books/upload" class="btn btn-primary">Upload Book</a>
</div>

@if (_loading)
{
    <div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div>
}
else if (_books.Count == 0)
{
    <p class="text-muted">No books uploaded yet. <a href="/admin/books/upload">Upload one now.</a></p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>Language</th>
                <th>Status</th>
                <th>Chunks</th>
                <th>Indexed At</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in _books)
            {
                <tr>
                    <td>@book.Title</td>
                    <td>@book.Author</td>
                    <td class="num">@book.Language.ToUpperInvariant()</td>
                    <td><span class="status-pill @StatusClass(book.Status)">@book.Status</span></td>
                    <td class="num">@book.TotalChunks</td>
                    <td class="num">@(book.IndexedAt?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                    <td>
                        @if (_reindexingIds.Contains(book.Id))
                        {
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="() => ReindexAsync(book.Id)">
                                Re-index
                            </button>
                        }
                        @if (_messages.TryGetValue(book.Id, out var msg))
                        {
                            <span class="ms-2 small @(msg.StartsWith("Error") || msg.StartsWith("Indexing failed") ? "text-danger" : "text-success")">
                                @msg
                            </span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

@code {
    private List<BookInfo> _books = [];
    private bool _loading = true;
    private string? _error;
    private readonly HashSet<int> _reindexingIds = [];
    private readonly Dictionary<int, string> _messages = [];

    private static string StatusClass(object? status)
    {
        var s = status?.ToString()?.ToLowerInvariant() ?? string.Empty;
        if (s.Contains("fail") || s.Contains("error")) return "is-failed";
        if (s.Contains("ing") || s.Contains("pending") || s.Contains("queue")) return "is-working";
        return "is-ok";
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _books = (await AdminBooks.GetBooksAsync()).ToList();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load books: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ReindexAsync(int bookId)
    {
        _reindexingIds.Add(bookId);
        _messages.Remove(bookId);

        try
        {
            var (success, message) = await AdminBooks.TriggerReindexAsync(bookId);
            _messages[bookId] = success ? "Indexing started." : $"Error: {message}";
        }
        catch (Exception ex)
        {
            _messages[bookId] = $"Error: {ex.Message}";
        }
        finally
        {
            _reindexingIds.Remove(bookId);
        }
    }
}

@page "/Error"
@using System.Diagnostics

<PageTitle>MedAssist — Error</PageTitle>

<div class="status-page">
    <div class="status-code">500</div>
    <h1>Something went wrong</h1>
    <p>An error occurred while processing your request. Try again, or head back to the query workspace.</p>
    <a href="/query" class="btn btn-primary">Go to Query</a>

    @if (ShowRequestId)
    {
        <p class="status-detail">Request ID: <code>@RequestId</code></p>
    }
</div>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}

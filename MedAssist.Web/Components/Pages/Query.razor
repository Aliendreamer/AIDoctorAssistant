@page "/query"
@using MedAssist.Data.Repositories
@using MedAssist.Shared.Models
@using MedAssist.Web.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using SourceType = MedAssist.Shared.Models.SourceType
@attribute [Authorize(Roles = "Doctor,Admin")]
@inject QueryService QueryService
@inject BookCatalogService BookCatalogService
@inject ChatHistoryRepository ChatHistoryRepo
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>MedAssist — Query</PageTitle>

<h1>Medical Query</h1>

<div class="query-form">
    <div class="form-group">
        <div class="d-flex align-items-center gap-2">
            <label for="queryType">Query Type</label>
            @if (_history.Count > 0)
            {
                <button class="btn btn-sm btn-outline-secondary ms-auto" @onclick="ClearHistoryAsync">Clear history</button>
            }
        </div>
        <select id="queryType" @bind="_queryType" @bind:after="OnQueryTypeChangedAsync" class="form-select">
            <option value="@QueryType.Disease">Disease Info</option>
            <option value="@QueryType.Symptoms">Symptoms</option>
            <option value="@QueryType.Treatment">Treatment</option>
        </select>
    </div>

    <div class="form-group">
        <label for="queryText">Question</label>
        <textarea id="queryText" @bind="_queryText" class="form-control" rows="3"
                  placeholder="e.g. Down Syndrome, or symptoms: fever cough shortness of breath"></textarea>
    </div>

    <div class="form-group">
        <label for="language">Language</label>
        <select id="language" @bind="_language" class="form-select">
            <option value="@LanguageFilter.Both">Both (EN + BG)</option>
            <option value="@LanguageFilter.English">English only</option>
            <option value="@LanguageFilter.Bulgarian">Bulgarian only</option>
        </select>
    </div>

    <div class="form-group">
        <label>Books to search</label>
        <div class="book-list">
            @foreach (var book in _books)
            {
                <label class="book-item">
                    <input type="checkbox" value="@book.BookId" @onchange="e => ToggleBook(book.BookId, (bool)(e.Value ?? false))" />
                    <span class="book-item-info">
                        <span class="book-item-title">@book.Title</span>
                        <span class="book-item-meta">@book.Author • @book.Language.ToUpperInvariant()</span>
                    </span>
                </label>
            }
            @if (_books.Count == 0)
            {
                <span class="text-muted">No books indexed yet.</span>
            }
        </div>
    </div>

    <div class="form-group">
        <label class="web-search-toggle">
            <input type="checkbox" @bind="_webSearchEnabled" />
            Search web if needed (PubMed)
        </label>
        @if (_webSearchEnabled)
        {
            <small class="text-muted">Results may include PubMed sources.</small>
        }
    </div>

    <button class="btn btn-primary" @onclick="SubmitQueryAsync" disabled="@_loading">
        @if (_loading)
        {
            <span class="spinner-border spinner-border-sm" role="status"></span>
            <span>Searching...</span>
        }
        else
        {
            <span>Search</span>
        }
    </button>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger mt-3">@_error</div>
}

@if (_history.Count > 0)
{
    <div class="conversation-thread mt-4">
        @foreach (var (msg, idx) in _history.Select((m, i) => (m, i)))
        {
            <div class="chat-message @(msg.Role == "user" ? "chat-message-user" : "chat-message-assistant")">
                <span class="chat-role">@(msg.Role == "user" ? "You" : "MedAssist")</span>
                <div class="chat-content">@msg.Content</div>
                @if (msg.Role == "assistant" && idx == _history.Count - 1 && _lastSources.Count > 0)
                {
                    <details class="chat-sources mt-1">
                        <summary class="text-muted small">Sources (@_lastSources.Count)</summary>
                        <ul class="list-unstyled mb-0 small">
                            @foreach (var src in _lastSources)
                            {
                                <li>
                                    @if (src.SourceType == SourceType.Book)
                                    {
                                        <span>@src.BookTitle</span>
                                        @if (!string.IsNullOrEmpty(src.ChapterTitle)) { <span> › @src.ChapterTitle</span> }
                                        @if (!string.IsNullOrEmpty(src.SectionTitle)) { <span> › @src.SectionTitle</span> }
                                        @if (src.PageStart.HasValue) { <span class="text-muted"> (p. @src.PageStart@(src.PageEnd.HasValue && src.PageEnd != src.PageStart ? $"–{src.PageEnd}" : ""))</span> }
                                    }
                                    else if (!string.IsNullOrEmpty(src.Url))
                                    {
                                        <a href="@src.Url" target="_blank">@(src.ArticleTitle ?? src.Url)</a>
                                    }
                                </li>
                            }
                        </ul>
                    </details>
                }
            </div>
        }
    </div>
}

@code {
    private List<BookInfo> _books = [];
    private HashSet<string> _selectedBookIds = [];
    private QueryType _queryType = QueryType.Disease;
    private LanguageFilter _language = LanguageFilter.Both;
    private string _queryText = string.Empty;
    private bool _webSearchEnabled;
    private bool _loading;
    private string? _error;
    private string? _userId;
    private List<ChatMessageDto> _history = [];
    private IReadOnlyList<SourceCitation> _lastSources = [];

    protected override async Task OnInitializedAsync()
    {
        _books = (await BookCatalogService.GetAllBooksAsync()).ToList();
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _userId = authState.User.Identity?.Name;
        await LoadHistoryAsync();
    }

    private async Task OnQueryTypeChangedAsync()
    {
        _lastSources = [];
        await LoadHistoryAsync();
    }

    private async Task LoadHistoryAsync()
    {
        if (_userId is null) return;
        var queryTypeKey = _queryType.ToString().ToLowerInvariant();
        var messages = await ChatHistoryRepo.GetRecentAsync(_userId, queryTypeKey, 10);
        _history = messages.Select(m => new ChatMessageDto(m.Role, m.Content)).ToList();
    }

    private void ToggleBook(string bookId, bool selected)
    {
        if (selected) _selectedBookIds.Add(bookId);
        else _selectedBookIds.Remove(bookId);
    }

    private async Task SubmitQueryAsync()
    {
        if (string.IsNullOrWhiteSpace(_queryText)) return;

        _loading = true;
        _error = null;

        try
        {
            var request = new QueryRequest
            {
                Query = _queryText,
                QueryType = _queryType,
                Language = _language,
                BookIds = _selectedBookIds.Count > 0 ? [.._selectedBookIds] : null,
                WebSearchEnabled = _webSearchEnabled
            };
            var result = await QueryService.ExecuteAsync(request, _userId);

            _history.Add(new ChatMessageDto("user", _queryText));
            _history.Add(new ChatMessageDto("assistant", result.Answer));
            _lastSources = result.Sources;
            _queryText = string.Empty;
        }
        catch (Exception ex)
        {
            _error = $"Query failed: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ClearHistoryAsync()
    {
        if (_userId is null) return;
        var queryTypeKey = _queryType.ToString().ToLowerInvariant();
        await ChatHistoryRepo.ClearAsync(_userId, queryTypeKey);
        _history.Clear();
        _lastSources = [];
    }
}

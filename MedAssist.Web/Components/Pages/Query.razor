@page "/query"
@using MedAssist.Data.Repositories
@using MedAssist.Shared.Models
@using MedAssist.Shared.Validation
@using MedAssist.Web.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using SourceType = MedAssist.Shared.Models.SourceType
@attribute [Authorize(Roles = "Doctor,Admin")]
@inject QueryService QueryService
@inject BookCatalogService BookCatalogService
@inject ChatHistoryRepository ChatHistoryRepo
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>MedAssist — Query</PageTitle>

<div class="query-page">

    <!-- ── Controls ── -->
    <div class="query-controls">
        <div class="query-controls-row">
            <div class="segmented" role="group" aria-label="Query type">
                @foreach (var (type, label) in _queryTypes)
                {
                    <button type="button"
                            class="segment @(_queryType == type ? "on" : "")"
                            aria-pressed="@(_queryType == type)"
                            @onclick="() => SelectQueryTypeAsync(type)">
                        @label
                    </button>
                }
            </div>

            <div class="controls-spacer"></div>

            <select @bind="_language" class="pill-select" aria-label="Language">
                <option value="@LanguageFilter.Both">EN + BG</option>
                <option value="@LanguageFilter.English">English only</option>
                <option value="@LanguageFilter.Bulgarian">Bulgarian only</option>
            </select>

            <label class="switch @(_webSearchEnabled ? "on" : "")">
                <input type="checkbox" @bind="_webSearchEnabled" />
                <span class="switch-track" aria-hidden="true"></span>
                <span class="switch-label">PubMed fallback</span>
            </label>

            <button class="clear-btn"
                    @onclick="ClearHistoryAsync"
                    disabled="@(_history.Count == 0)">
                Clear history
            </button>
        </div>

        @if (_books.Count > 0)
        {
            <div class="book-chips">
                @foreach (var book in _books)
                {
                    var selected = _selectedBookIds.Contains(book.BookId);
                    <label class="book-chip @(selected ? "selected" : "")" title="@book.Author">
                        <input type="checkbox" value="@book.BookId"
                               @onchange="e => ToggleBook(book.BookId, (bool)(e.Value ?? false))" />
                        <span class="chip-dot" aria-hidden="true"></span>
                        @book.Title
                        <span class="book-chip-lang">@book.Language</span>
                    </label>
                }
            </div>
        }
    </div>

    <!-- ── Chat area ── -->
    <div class="chat-container" id="chat-container">
        @if (_history.Count == 0 && !_loading)
        {
            <div class="chat-empty">
                <div class="chat-empty-mark" aria-hidden="true">+</div>
                <h2 class="chat-empty-title">Ask a clinical question</h2>
                <p class="chat-empty-sub">
                    Answers are drawn from your indexed medical library and cited to source.
                    Pick a query mode above and, optionally, narrow to specific books.
                </p>
            </div>
        }
        else
        {
            @foreach (var (msg, idx) in _history.Select((m, i) => (m, i)))
            {
                <div class="turn @(msg.Role == "user" ? "turn-user" : "turn-assistant")">
                    <div class="turn-label">
                        <span>@(msg.Role == "user" ? "You" : "MedAssist")</span>
                        @if (MessageHasWebSources(idx))
                        {
                            <span class="web-badge" title="This answer includes web search results">Web</span>
                        }
                    </div>

                    @if (msg.Role == "user")
                    {
                        <div class="user-msg">@msg.Content</div>
                    }
                    else
                    {
                        var msgSources = GetMessageSources(idx);
                        var segments = CitationMarkers.Parse(msg.Content, msgSources.Count);
                        <div class="answer">
                            <div class="answer-body">@foreach (var seg in segments)
                                {
                                    if (seg.CitationNumber is int citeNum)
                                    {<sup class="cite" title="@SourceLabel(msgSources, citeNum)">@citeNum</sup>}
                                    else
                                    {@seg.Text}
                                }</div>

                            @if (msgSources is { Count: > 0 })
                            {
                                <div class="sources">
                                    <div class="sources-head">
                                        Sources <span class="sources-count">@msgSources.Count</span>
                                    </div>
                                    @foreach (var (src, i) in msgSources.Select((s, i) => (s, i)))
                                    {
                                        <div class="source @(src.SourceType == SourceType.Web ? "source-web" : "")">
                                            <span class="source-idx">@(i + 1)</span>
                                            @if (src.SourceType == SourceType.Book)
                                            {
                                                <span class="source-path">
                                                    <b>@src.BookTitle</b>
                                                    @if (!string.IsNullOrEmpty(src.ChapterTitle)) { <span class="sep">›</span> @src.ChapterTitle }
                                                    @if (!string.IsNullOrEmpty(src.SectionTitle)) { <span class="sep">›</span> @src.SectionTitle }
                                                </span>
                                                @if (src.PageStart.HasValue)
                                                {
                                                    <span class="source-meta">p.&nbsp;@src.PageStart@(src.PageEnd.HasValue && src.PageEnd != src.PageStart ? $"–{src.PageEnd}" : "")</span>
                                                }
                                                else
                                                {
                                                    <span class="source-meta"></span>
                                                }
                                            }
                                            else if (src.SourceType == SourceType.Web)
                                            {
                                                <span class="source-path">
                                                    @if (WebFetchPolicy.IsHttpUrl(src.Url))
                                                    {
                                                        <a href="@src.Url" target="_blank" rel="noopener noreferrer">@(src.ArticleTitle ?? src.Url)</a>
                                                    }
                                                    else
                                                    {
                                                        <span>@(src.ArticleTitle ?? "Web source")</span>
                                                    }
                                                    <span class="web-tag">@(src.SourceName ?? "Web")</span>
                                                </span>
                                                <span class="source-meta"></span>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            @if (_loading)
            {
                <div class="turn turn-assistant">
                    <div class="turn-label"><span>MedAssist</span></div>
                    <div class="answer thinking">
                        <span class="thinking-dots" aria-hidden="true"><i></i><i></i><i></i></span>
                        <span class="thinking-text">Searching the library…</span>
                    </div>
                </div>
            }
        }
    </div>

    <!-- ── Error ── -->
    @if (_error is not null)
    {
        <div class="query-error-wrap">
            <div class="alert alert-danger mb-0">@_error</div>
        </div>
    }

    <!-- ── Input ── -->
    <div class="chat-input-area">
        <div class="composer">
            <textarea @bind="_queryText" @bind:event="oninput"
                      @onkeydown="HandleKeyDown"
                      rows="1"
                      placeholder="Ask a clinical question…"></textarea>
            <button class="chat-send-btn" @onclick="SubmitQueryAsync" disabled="@_loading">
                @if (_loading)
                {
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                }
                else
                {
                    <span>Send</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                }
            </button>
        </div>
        <div class="composer-hint">
            <span><kbd>Enter</kbd> send</span>
            <span><kbd>Shift</kbd>+<kbd>Enter</kbd> new line</span>
        </div>
    </div>
</div>

@code {
    private static readonly (QueryType Type, string Label)[] _queryTypes =
    [
        (QueryType.GlobalSearch, "Global search"),
        (QueryType.Disease, "Disease"),
        (QueryType.Symptoms, "Symptoms"),
        (QueryType.Treatment, "Treatment"),
        (QueryType.DifferentialDiagnosis, "Differential"),
    ];

    private List<BookInfo> _books = [];
    private HashSet<string> _selectedBookIds = [];
    private QueryType _queryType = QueryType.GlobalSearch;
    private LanguageFilter _language = LanguageFilter.Both;
    private string _queryText = string.Empty;
    private bool _webSearchEnabled;
    private bool _loading;
    private string? _error;
    private string? _userId;
    private List<ChatMessageDto> _history = [];
    private Dictionary<int, IReadOnlyList<SourceCitation>> _sourcesPerMessage = [];

    protected override async Task OnInitializedAsync()
    {
        _books = (await BookCatalogService.GetAllBooksAsync()).ToList();
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _userId = authState.User.Identity?.Name;
        await LoadHistoryAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_history.Count > 0)
        {
            await JS.InvokeVoidAsync("medassist.scrollToBottom", "chat-container");
        }
    }

    private async Task SelectQueryTypeAsync(QueryType type)
    {
        if (_queryType == type) return;
        _queryType = type;
        await OnQueryTypeChangedAsync();
    }

    private async Task OnQueryTypeChangedAsync()
    {
        _sourcesPerMessage.Clear();
        await LoadHistoryAsync();
    }

    private async Task LoadHistoryAsync()
    {
        if (_userId is null) return;
        var queryTypeKey = _queryType.ToString().ToLowerInvariant();
        var messages = await ChatHistoryRepo.GetRecentAsync(_userId, queryTypeKey, 10);
        _history = messages.Select(m => new ChatMessageDto(m.Role, m.Content)).ToList();
    }

    private void ToggleBook(string bookId, bool selected)
    {
        if (selected) _selectedBookIds.Add(bookId);
        else _selectedBookIds.Remove(bookId);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey && !_loading)
        {
            await SubmitQueryAsync();
        }
    }

    private async Task SubmitQueryAsync()
    {
        if (string.IsNullOrWhiteSpace(_queryText)) return;

        _loading = true;
        _error = null;

        try
        {
            var request = new QueryRequest
            {
                Query = _queryText,
                QueryType = _queryType,
                Language = _language,
                BookIds = _selectedBookIds.Count > 0 ? [.._selectedBookIds] : null,
                WebSearchEnabled = _webSearchEnabled
            };
            var result = await QueryService.ExecuteAsync(request, _userId);

            _history.Add(new ChatMessageDto("user", _queryText));
            _history.Add(new ChatMessageDto("assistant", result.Answer));
            if (result.Sources.Count > 0)
            {
                _sourcesPerMessage[_history.Count - 1] = result.Sources;
            }
            _queryText = string.Empty;
        }
        catch (Exception ex)
        {
            _error = $"Couldn't complete the query: {ex.Message}. Try again or rephrase your question.";
        }
        finally
        {
            _loading = false;
        }
    }

    private IReadOnlyList<SourceCitation> GetMessageSources(int idx)
        => _sourcesPerMessage.TryGetValue(idx, out var sources) ? sources : [];

    // Tooltip for an inline [n] citation marker — names the source it maps to.
    private static string SourceLabel(IReadOnlyList<SourceCitation> sources, int n)
    {
        if (n < 1 || n > sources.Count) return $"Source {n}";
        var s = sources[n - 1];
        if (s.SourceType == SourceType.Book)
        {
            var label = s.BookTitle ?? "Book";
            if (s.PageStart.HasValue)
            {
                label += $", p. {s.PageStart}" +
                    (s.PageEnd.HasValue && s.PageEnd != s.PageStart ? $"–{s.PageEnd}" : "");
            }
            return label;
        }
        return s.ArticleTitle ?? s.SourceName ?? "Web source";
    }

    private bool MessageHasWebSources(int idx)
        => _sourcesPerMessage.TryGetValue(idx, out var sources) && sources.Any(s => s.SourceType == SourceType.Web);

    private async Task ClearHistoryAsync()
    {
        if (_userId is null) return;
        var queryTypeKey = _queryType.ToString().ToLowerInvariant();
        await ChatHistoryRepo.ClearAsync(_userId, queryTypeKey);
        _history.Clear();
        _sourcesPerMessage.Clear();
    }
}

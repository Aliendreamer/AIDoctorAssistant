@using MedAssist.Shared.Models
@using MedAssist.Shared.Validation

<div class="citation web-citation">
    <span class="badge bg-info me-2">🌐 @(Citation.SourceName ?? "Web")</span>
    @if (!string.IsNullOrWhiteSpace(Citation.ArticleTitle))
    {
        <strong>@Citation.ArticleTitle</strong>
    }
    @if (WebFetchPolicy.IsHttpUrl(Citation.Url))
    {
        <a href="@Citation.Url" target="_blank" rel="noopener noreferrer" class="ms-2">@Citation.Url</a>
    }
    else if (!string.IsNullOrWhiteSpace(Citation.Url))
    {
        <span class="ms-2">@Citation.Url</span>
    }
</div>

@code {
    [Parameter, EditorRequired] public SourceCitation Citation { get; set; } = default!;
}

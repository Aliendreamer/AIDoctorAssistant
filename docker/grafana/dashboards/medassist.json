{
  "title": "MedAssist",
  "uid": "medassist-main",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request Rate",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_request_duration_seconds_count{job=\"medassist-web\"}[1m])",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Query Duration by Plugin (p95)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(query_duration_seconds_bucket{job=\"medassist-web\"}[5m]))",
          "legendFormat": "{{plugin_type}} p95"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Qdrant Results Returned",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(qdrant_results_total{job=\"medassist-web\"}[1m])",
          "legendFormat": "results/s"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Indexer Chunk Throughput",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(indexer_chunks_total[1m])",
          "legendFormat": "chunks/s"
        }
      ]
    }
  ],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s"
}

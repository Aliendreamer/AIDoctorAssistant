      "headers": [
        { "name": "Authorization", "value": "Bearer {{ _.token }}" },
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"query\": \"pneumonia treatment guidelines\",\n  \"queryType\": \"Disease\",\n  \"language\": \"Both\",\n  \"webSearchEnabled\": false\n}"
      },
      "parameters": [],
      "authentication": {}

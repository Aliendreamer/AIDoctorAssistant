{
  "_type": "export",
  "__export_format": 4,
  "__export_date": "2026-05-16",
  "__export_source": "medassist-api",
  "resources": [
    {
      "_id": "wrk_medassist",
      "_type": "workspace",
      "parentId": null,
      "name": "MedAssist API",
      "description": "Bilingual RAG medical assistant — import into Yaak via File > Import",
      "scope": "collection"
    },
    {
      "_id": "env_local",
      "_type": "environment",
      "parentId": "wrk_medassist",
      "name": "Local",
      "data": {
        "baseUrl": "http://localhost:8080",
        "token": ""
      }
    },
    {
      "_id": "fld_auth",
      "_type": "request_group",
      "parentId": "wrk_medassist",
      "name": "Auth"
    },
    {
      "_id": "fld_books",
      "_type": "request_group",
      "parentId": "wrk_medassist",
      "name": "Books"
    },
    {
      "_id": "fld_admin",
      "_type": "request_group",
      "parentId": "wrk_medassist",
      "name": "Admin"
    },
    {
      "_id": "fld_query",
      "_type": "request_group",
      "parentId": "wrk_medassist",
      "name": "Query"
    },
    {

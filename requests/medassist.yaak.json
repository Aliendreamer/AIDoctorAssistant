    {
      "_id": "req_login_admin",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Login (admin)",
      "method": "POST",
      "url": "{{ _.baseUrl }}/api/auth/login",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"username\": \"admin\",\n  \"password\": \"medassist123\"\n}"
      },
      "parameters": [],
      "authentication": {}
    },
    {
      "_id": "req_login_doctor",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Login (doctor)",
      "method": "POST",
      "url": "{{ _.baseUrl }}/api/auth/login",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"username\": \"doctor\",\n  \"password\": \"doctor123\"\n}"
      },
      "parameters": [],
      "authentication": {}
    },
    {
      "_id": "req_books_list",
      "_type": "request",
      "parentId": "fld_books",
      "name": "List books",
      "method": "GET",
      "url": "{{ _.baseUrl }}/api/books",
      "headers": [
        { "name": "Authorization", "value": "Bearer {{ _.token }}" }
      ],
      "body": {
        "mimeType": ""
      },
      "parameters": [],
      "authentication": {}
    },
    {
      "_id": "req_books_index",
      "_type": "request",
      "parentId": "fld_admin",
      "name": "Trigger indexing",
      "method": "POST",
      "url": "{{ _.baseUrl }}/api/admin/index",
      "parameters": [
        { "name": "id", "value": "1" }
      ],
      "headers": [
        { "name": "Authorization", "value": "Bearer {{ _.token }}" }
      ],
      "body": { "mimeType": "" },
      "authentication": {}
    },
    {
      "_id": "req_books_upload",
      "_type": "request",
      "parentId": "fld_admin",
      "name": "Upload book (PDF)",
      "method": "POST",
      "url": "{{ _.baseUrl }}/api/admin/books/upload",
      "headers": [
        { "name": "Authorization", "value": "Bearer {{ _.token }}" }
      ],
      "body": {
        "mimeType": "multipart/form-data",
        "params": [
          { "name": "BookId", "value": "my-book-v1" },
          { "name": "Title", "value": "My Medical Book" },
          { "name": "Author", "value": "Author Name" },
          { "name": "Language", "value": "en" },
          { "name": "Edition", "value": "1st" },
          { "name": "File", "value": "", "type": "file", "fileName": "" }
        ]
      },
      "parameters": [],
      "authentication": {}
    },
    {
